LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent dispatched by the incident trigger (must match agent_name in agent.py).
LIVEKIT_AGENT_NAME=my-agent

# Outbound SIP for the automated incident call. Use EITHER a stored trunk id...
LIVEKIT_SIP_TRUNK_ID=

# ...OR inline Twilio Elastic SIP Trunk config (used only if no trunk id is set).
SIP_TRUNK_HOSTNAME=
SIP_AUTH_USERNAME=
SIP_AUTH_PASSWORD=
SIP_FROM_NUMBER=
SIP_DESTINATION_COUNTRY=US
